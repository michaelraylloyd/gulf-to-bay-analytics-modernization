  "ActivityID": "A5AFB472-2C3E-4835-BD9C-D78DBAF19D42",
  "RequestID": null,
  "CommandText": "DEFINE\n    VAR OrderDate_ =\n        FILTER (\n            FactSales,\n            YEAR ( FactSales[OrderDate] ) < 2019\n        )\n    VAR SalesAmount_ =\n        FILTER (\n            FactSales,\n            FactSales[SalesAmount] > 0\n        )\n    //Define main query variable to evaluate using SELECTCOLUMNS later to order columns appropriately\n    VAR Main_ =\n        ADDCOLUMNS (\n            SUMMARIZECOLUMNS (\n                DimGeography[Country],\n                DimGeography[State Province],\n                DimGeography[City],\n                OrderDate_,\n                SalesAmount_,\n                \"Total Customers\", DISTINCTCOUNT ( DimCustomer[CustomerKey] ),\n                \"Total Orders\", SUM ( FactSales[OrderQuantity] ),\n                \"Total Sales\",\n                    FORMAT (\n                        SUM ( FactSales[SalesAmount] ),\n                        \"Currency\"\n                    )\n            ),\n            \"Continent\",\n                SWITCH (\n                    DimGeography[Country],\n                    \"Australia\", \"Australia\",\n                    \"Canada\", \"North America\",\n                    \"France\", \"Europe\",\n                    \"Germany\", \"Europe\",\n                    \"United Kingdom\", \"Europe\",\n                    \"United States\", \"North America\",\n                    \"N/A\"\n                )\n        ) //Evauate main query and select columns in appropriate order\n\nEVALUATE\nSELECTCOLUMNS (\n    Main_,\n    \"Continent\", [Continent],\n    \"Country\", [Country],\n    \"State Province\", [State Province],\n    \"City\", [City],\n    \"Total Customers\", [Total Customers],\n    \"Total Orders\", [Total Orders],\n    \"Total Sales\", [Total Sales]\n)\nORDER BY\n    [Continent],\n    [Country],\n    [State Province],\n    [City]",
  "Parameters": null,
  "StartDatetime": "2023-07-15T12:33:57.983333-04:00"
}